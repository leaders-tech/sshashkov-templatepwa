# This file is the only student-facing config for local development and local e2e tests.
# Edit this file when you want to change local ports, local URLs, secrets, or test settings.
# Copy one line here when you add another local setting that students may need to change.
APP_MODE=dev
APP_HOST=localhost
APP_PORT=3101
APP_PUBLIC_HOST=localhost
DB_PATH=./dev.sqlite3
COOKIE_SECRET=change-this-secret
FRONTEND_PUBLIC_HOST=localhost
FRONTEND_BIND_HOST=localhost
FRONTEND_PORT=5101
WIFI_INTERFACE=en0
LAN_FRONTEND_PORT=5104
LAN_BACKEND_PORT=3104
E2E_BACKEND_HOST=127.0.0.1
E2E_BACKEND_PORT=3103
E2E_FRONTEND_HOST=127.0.0.1
E2E_FRONTEND_PORT=5103
E2E_DB_DIR=/tmp
E2E_COOKIE_SECRET=playwright-secret
