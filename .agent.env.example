# This file is the hidden config for Codex, Claude, and other repo agents.
# Edit this file when agent-only ports, agent runtime files, or agent browser settings need to change.
# Copy one line here when you add another hidden agent setting.
AGENT_BACKEND_HOST=127.0.0.1
AGENT_BACKEND_PORT=3102
AGENT_FRONTEND_HOST=127.0.0.1
AGENT_FRONTEND_PORT=5102
AGENT_RUNTIME_DIR=.agent
AGENT_DB_PATH=.agent/agent.sqlite3
AGENT_COOKIE_SECRET=agent-secret
AGENT_BROWSER_WIDTH=1280
AGENT_BROWSER_HEIGHT=900
