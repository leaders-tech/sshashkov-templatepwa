# This file is the only student-facing config for Docker, Dokploy, and Docker e2e tests.
# Edit this file when you want to change Docker URLs, Docker secrets, Docker project names, or Docker test settings.
# Copy one line here when you add another Docker setting that students may need to change.
COMPOSE_PROJECT_NAME=templatepwa_local
APP_MODE=dev
COOKIE_SECRET=local-docker-secret
DB_PATH=/data/app.sqlite3
FRONTEND_ORIGIN=http://localhost:5105
# In tlfpaas and same-origin production, keep the frontend API base path at /api.
VITE_BACKEND_URL=/api
GATEWAY_PORT=5105
E2E_COMPOSE_PROJECT_NAME=templatepwa_e2e
E2E_APP_MODE=dev
E2E_COOKIE_SECRET=playwright-docker-secret
E2E_FRONTEND_ORIGIN=http://127.0.0.1:5106
E2E_VITE_BACKEND_URL=/api
E2E_GATEWAY_PORT=5106
E2E_FRONTEND_URL=http://127.0.0.1:5106
